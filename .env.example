# =====================================================================
# AXIOM — environment variables (VPS .env). Never commit real values.
# =====================================================================

# --- Runtime ---
APP_ENV=production              # production | staging | dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
SENTRY_DSN=

# --- Database / cache ---
DATABASE_URL=postgresql+asyncpg://axiom:axiom@127.0.0.1:5432/axiom
REDIS_URL=redis://127.0.0.1:6379/0

# --- Auth / crypto ---
JWT_SECRET=change-me-32-bytes-min
AES_MASTER_KEY=base64-32byte-key-for-broker-creds

# --- Zerodha Kite (data feed) ---
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# --- Razorpay ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Signal engine tuning ---
SIGNAL_MIN_LAYERS=3
SIGNAL_WINDOW_SECONDS=60
INDIA_VIX_HARD_CAP=25.0
DAILY_LOSS_CAP_PCT=3.0
